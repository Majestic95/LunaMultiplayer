<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LunaServerGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="650"
        x:Class="LunaServerGui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Luna Server GUI"
        Width="900" Height="650">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top toolbar: theme switcher on the right.
             Slice-1E polish will add a persistence shim
             (%APPDATA%/LunaServerGui/theme.json) so this choice survives
             restart; today it's session-scoped. -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,4">
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Theme:" VerticalAlignment="Center" Opacity="0.7"/>
                <ComboBox ItemsSource="{Binding ThemeChoices}"
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                          MinWidth="100"
                          ToolTip.Tip="Light is brighter and consistent regardless of Windows theme; Dark matches dark-mode operators; System follows your OS preference."/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Folder &amp; Setup">
                <ContentControl Content="{Binding FolderSetup}"/>
            </TabItem>
            <TabItem Header="Launch Settings">
                <ContentControl Content="{Binding LaunchSettings}"/>
            </TabItem>
            <TabItem Header="Server Console">
                <ContentControl Content="{Binding ServerControl}"/>
            </TabItem>
            <TabItem Header="Connections">
                <ContentControl Content="{Binding Connections}"/>
            </TabItem>
            <TabItem Header="Admin Actions">
                <ContentControl Content="{Binding AdminActions}"/>
            </TabItem>
        </TabControl>

        <!-- Surfaced when MainWindow.OnClosing refuses to close because the
             server is still running. Bound to CloseBlockedMessage which the
             VM sets/clears via TryAllowClose(). -->
        <Border Grid.Row="2"
                IsVisible="{Binding CloseBlockedMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Background="{DynamicResource SystemControlBackgroundAccentBrush}"
                Padding="12,8">
            <TextBlock Text="{Binding CloseBlockedMessage}"
                       Foreground="White"
                       TextWrapping="Wrap"/>
        </Border>

    </Grid>
</Window>
