<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LunaServerGui.ViewModels"
             xmlns:models="using:LunaServerGui.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LunaServerGui.Views.ConnectionsView"
             x:DataType="vm:ConnectionsViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16" RowSpacing="8">

        <!-- Caveat banner. The server doesn't see mod-mismatch rejections
             (validation runs client-side in ModFileHandler; client self-
             disconnects without telling the server why). Surface this
             upfront so the operator doesn't expect mod-issues to appear. -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundAccentBrush}"
                CornerRadius="3" Padding="12,8">
            <TextBlock Foreground="White" TextWrapping="Wrap">
                <Run Text="Note:" FontWeight="SemiBold"/>
                <Run Text="This tab shows server-side handshake outcomes (banned, server-full, version mismatch, invalid name, name-taken). Mod-mismatch rejections are NOT visible here — they happen client-side, and the server has no log line for them. Check the affected client's KSP.log for those."/>
            </TextBlock>
        </Border>

        <!-- Summary chips + Clear -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock>
                    <Run Text="Total: " FontWeight="SemiBold"/>
                    <Run Text="{Binding TotalCount}"/>
                </TextBlock>
                <TextBlock Foreground="#1B5E20">
                    <Run Text="✓ Accepted: " FontWeight="SemiBold"/>
                    <Run Text="{Binding AcceptedCount}"/>
                </TextBlock>
                <TextBlock Foreground="#C62828">
                    <Run Text="✗ Rejected: " FontWeight="SemiBold"/>
                    <Run Text="{Binding RejectedCount}"/>
                </TextBlock>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Clear"
                    Command="{Binding ClearCommand}"
                    ToolTip.Tip="Discard the captured event list. Does not affect the server or its log files."/>
        </Grid>

        <!-- Column headers -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,4">
            <Grid ColumnDefinitions="80,40,200,90,*" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Time"     FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="Outcome"  FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Grid.Column="2" Text="Player"   FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Grid.Column="3" Text="UID"      FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Grid.Column="4" Text="Details"  FontWeight="SemiBold" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Event list -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="2">
            <Panel>
                <!-- Empty placeholder when no events captured yet. Bound to
                     IsEmpty (a derived bool) rather than ObjectConverters.Equal
                     against ConverterParameter=0 — the latter compares an int to
                     a string "0" and never matches (review MUST FIX #1). -->
                <TextBlock IsVisible="{Binding IsEmpty}"
                           Text="No connection events captured. Start the server and have a client try to connect."
                           Margin="16"
                           Opacity="0.6"/>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Events}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ConnectionEvent">
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="4,4">
                                    <Grid ColumnDefinitions="80,40,200,90,*" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding TimestampDisplay}"
                                                   FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding OutcomeGlyph}"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold"
                                                   FontSize="14"/>
                                        <SelectableTextBlock Grid.Column="2"
                                                             Text="{Binding PlayerName}"
                                                             FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                                             FontSize="12"/>
                                        <SelectableTextBlock Grid.Column="3"
                                                             Text="{Binding UidShort}"
                                                             ToolTip.Tip="{Binding UniqueIdentifier}"
                                                             FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                                             FontSize="12"
                                                             Opacity="0.7"/>
                                        <SelectableTextBlock Grid.Column="4"
                                                             Text="{Binding Details}"
                                                             FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                                             FontSize="12"
                                                             TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Panel>
        </Border>

    </Grid>
</UserControl>
