<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LunaServerGui.ViewModels"
             xmlns:models="using:LunaServerGui.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LunaServerGui.Views.LaunchSettingsView"
             x:DataType="vm:LaunchSettingsViewModel">

    <Grid RowDefinitions="Auto,*" Margin="16" RowSpacing="8">

        <!-- Top status bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
            <Button Grid.Column="1"
                    Content="Reload"
                    Command="{Binding ReloadCommand}"
                    ToolTip.Tip="Re-read all settings files from disk."/>
        </Grid>

        <!-- Either the no-groups placeholder or the per-group TabControl -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="2">

            <Panel>
                <!-- Empty-state placeholder, shown when HasGroups is false. -->
                <TextBlock IsVisible="{Binding !HasGroups}"
                           Text="No settings loaded."
                           Margin="16"
                           Opacity="0.6"/>

                <!-- Per-group nested tabs. -->
                <TabControl IsVisible="{Binding HasGroups}"
                            ItemsSource="{Binding Groups}"
                            TabStripPlacement="Left">
                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="models:SettingsGroup">
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate x:DataType="models:SettingsGroup">
                            <Grid RowDefinitions="Auto,Auto,*" Margin="12" RowSpacing="8">

                                <!-- Header: file path + status badge -->
                                <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="4">
                                    <TextBlock>
                                        <Run Text="File: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding FilePath}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Status: " FontWeight="SemiBold"/>
                                        <Run Text="{Binding Status}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Detail (missing/parse-error explanation) + defaults-shown header
                                     when Status is not Loaded, so the operator does not mistake
                                     placeholder POCO defaults for the file's actual content. -->
                                <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="2">
                                    <TextBlock Text="{Binding Detail}"
                                               IsVisible="{Binding Detail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                               Foreground="{DynamicResource SystemAccentColor}"
                                               TextWrapping="Wrap"
                                               FontStyle="Italic"/>
                                    <TextBlock Text="(values below are POCO defaults — not from the file)"
                                               IsVisible="{Binding !ValuesAreFromFile}"
                                               Foreground="{DynamicResource SystemAccentColor}"
                                               FontStyle="Italic"/>
                                </StackPanel>

                                <!-- Fields list. Dimmed via SettingsGroup.FieldsOpacity (1.0 / 0.55)
                                     when values are POCO defaults rather than file content. -->
                                <ScrollViewer Grid.Row="2"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto"
                                              Opacity="{Binding FieldsOpacity}">
                                    <ItemsControl ItemsSource="{Binding Fields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:SettingsField">
                                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,6">
                                                    <Grid ColumnDefinitions="220,*" ColumnSpacing="12">
                                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding DeclaredType.Name}"
                                                                       Opacity="0.55"
                                                                       FontSize="11"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2">
                                                            <SelectableTextBlock Text="{Binding DisplayValue}"
                                                                                 FontFamily="Cascadia Mono, Consolas, Menlo, monospace"/>
                                                            <TextBlock Text="{Binding Comment}"
                                                                       IsVisible="{Binding Comment, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                       Opacity="0.7"
                                                                       FontSize="11"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Panel>
        </Border>

    </Grid>
</UserControl>
