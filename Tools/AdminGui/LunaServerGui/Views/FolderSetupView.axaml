<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LunaServerGui.ViewModels"
             xmlns:models="using:LunaServerGui.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LunaServerGui.Views.FolderSetupView"
             x:DataType="vm:FolderSetupViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="16" RowSpacing="8">

        <TextBlock Grid.Row="0"
                   Text="Select your LMPServer folder. The folder should contain Server.exe (Windows), Server (Linux), or Server.dll (framework-dependent)."
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Name="BrowseButton" Content="Browse..." Click="OnBrowseClick"
                    IsEnabled="{Binding !IsBrowsing}"/>
            <TextBlock Text="{Binding SelectedFolderPath, FallbackValue='(no folder selected)'}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2"
                IsVisible="{Binding Validation, Converter={x:Static ObjectConverters.IsNotNull}}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" Padding="8" CornerRadius="2">
            <StackPanel Spacing="4">
                <TextBlock FontWeight="SemiBold">
                    <Run Text="Status: "/>
                    <Run Text="{Binding Validation.Status}"/>
                </TextBlock>
                <TextBlock IsVisible="{Binding Validation.CanLaunch}"
                           Foreground="{DynamicResource SystemControlForegroundAccentBrush}">
                    <Run Text="Entrypoint: "/>
                    <Run Text="{Binding Validation.Entrypoint.ExecutablePath, FallbackValue=''}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3">
            <ItemsControl ItemsSource="{Binding Validation.Findings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:ValidationFinding">
                        <Grid ColumnDefinitions="80,*" Margin="0,2">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Severity}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Top"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Message}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
