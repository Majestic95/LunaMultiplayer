<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LunaServerGui.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LunaServerGui.Views.ServerControlView"
             x:DataType="vm:ServerControlViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16" RowSpacing="8">

        <!-- State + control buttons -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
            <Button Grid.Column="0" Content="Start" Command="{Binding StartCommand}"
                    ToolTip.Tip="Launch the server with the entrypoint resolved on the Folder &amp; Setup tab. Disabled until a valid folder is selected and while the server is running."/>
            <Button Grid.Column="1" Content="Stop" Command="{Binding StopCommand}"
                    ToolTip.Tip="Closes stdin then kills the process tree after a grace period. Available only while the server is Running."/>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock>
                    <Run Text="State: " FontWeight="SemiBold"/>
                    <Run Text="{Binding State}"/>
                </TextBlock>
                <TextBlock IsVisible="{Binding LastExitCode, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Run Text="Last exit code: " FontWeight="SemiBold"/>
                    <Run Text="{Binding LastExitCode}"/>
                </TextBlock>
            </StackPanel>
            <TextBlock Grid.Column="3"
                       Text="{Binding LastError}"
                       IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       VerticalAlignment="Center"
                       ToolTip.Tip="{Binding LastError}"/>
        </Grid>

        <!-- Log pane: TextBox provides built-in scrolling + selection + copy. -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                CornerRadius="2">
            <ScrollViewer Name="LogScrollViewer" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                                       FontSize="12"
                                       TextWrapping="NoWrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Command input -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Text="{Binding CommandInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="/listclients   |   /say hello   |   /kick PlayerName"
                     KeyDown="OnCommandInputKeyDown"/>
            <Button Grid.Column="1"
                    Content="Send"
                    Command="{Binding SendInputCommand}"
                    IsDefault="True"
                    ToolTip.Tip="Send the typed line to the server's stdin (Enter also sends). Available only while the server is Running."/>
        </Grid>

    </Grid>
</UserControl>
